rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Protects against ID Poisoning and Denial of Wallet attacks
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Helper to reference existing document structure safely
    function existing() {
      return resource.data;
    }

    // Validation blueprints for BlogPost
    function isValidBlogPost(data) {
      return data.keys().hasAll([
        'id', 'title', 'category', 'readTime', 'location', 
        'glassClass', 'imageType', 'author', 'description', 
        'content', 'specs', 'views', 'likes', 'dateStr', 'authorId'
      ]) 
      && data.keys().size() <= 18
      && data.id is string && data.id.size() <= 128
      && data.title is string && data.title.size() <= 300
      && data.category is string && data.category.size() <= 100
      && data.readTime is string && data.readTime.size() <= 50
      && data.location is string && data.location.size() <= 150
      && data.glassClass is string && data.glassClass.size() <= 150
      && data.imageType is string && data.imageType.size() <= 50
      && data.description is string && data.description.size() <= 1000
      && data.content is string && data.content.size() <= 50000
      && data.views is int && data.views >= 0
      && data.likes is int && data.likes >= 0
      && data.dateStr is string && data.dateStr.size() <= 100
      && data.authorId is string && (data.authorId == 'system_genesis_admin' || (isSignedIn() && data.authorId == request.auth.uid));
    }

    // Validation blueprints for UserProfiles
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'createdAt'])
      && data.keys().size() <= 6
      && data.uid is string && (data.uid == request.auth.uid || data.uid == 'system_genesis_admin')
      && data.email is string && data.email.size() <= 254
      && data.displayName is string && data.displayName.size() <= 150
      && data.photoURL is string && data.photoURL.size() <= 1000;
    }

    // Validation blueprint for Likes relationship
    function isValidLike(data) {
      return data.keys().hasAll(['id', 'userId', 'postId', 'createdAt'])
      && data.keys().size() == 4
      && data.id is string && data.id.size() <= 128
      && data.userId is string && data.userId == request.auth.uid
      && data.postId is string && data.postId.size() <= 128;
    }

    // --- COLLECTION PATH MATCHERS ---

    // 1. BlogPost collection
    match /posts/{postId} {
      allow get, list: if true; // Publicly readable articles
      
      allow create: if (incoming().authorId == 'system_genesis_admin' || isSignedIn()) 
        && isValidId(postId) 
        && isValidBlogPost(incoming()) 
        && incoming().id == postId;

      allow update: if 
        // Tier 2 Action for Anonymous Readers: Can only increment / update view counter
        (incoming().diff(existing()).affectedKeys().hasOnly(['views'])
          && incoming().id == existing().id
          && incoming().authorId == existing().authorId
          && incoming().title == existing().title
          && incoming().content == existing().content
        )
        ||
        (isSignedIn() && (
          // Tier 1 Action: Original author can edit metadata & text
          (isOwner(existing().authorId) 
            && incoming().authorId == existing().authorId
            && incoming().id == existing().id
            && incoming().diff(existing()).affectedKeys().hasOnly([
              'title', 'category', 'readTime', 'location', 'glassClass', 
              'imageType', 'description', 'content', 'specs', 'dateStr'
            ])
          )
          ||
          // Tier 2 Action for Logged-In Reader: Update views and likes counts
          (incoming().diff(existing()).affectedKeys().hasOnly(['views', 'likes'])
            && incoming().id == existing().id
            && incoming().authorId == existing().authorId
            && incoming().title == existing().title
            && incoming().content == existing().content
          )
        ));

      allow delete: if isSignedIn() && isOwner(existing().authorId);
    }

    // 2. Users core configurations (Split Privacy strategy)
    match /users/{userId} {
      allow get: if isSignedIn(); // Users can view users' basic details (display names, etc.) for visual display
      
      allow create: if isOwner(userId) 
        && isValidId(userId)
        && isValidUser(incoming());
        
      allow update: if isOwner(userId)
        && incoming().uid == existing().uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])
        && isValidUser(incoming());

      allow delete: if isOwner(userId);
      
      // Isolated private subcollection under users for likes mapping
      match /likes/{likeId} {
        allow get, list: if isOwner(userId);
        
        allow create: if isOwner(userId)
          && isValidId(likeId)
          && isValidLike(incoming())
          && incoming().id == likeId;
          
        allow delete: if isOwner(userId);
      }
    }
  }
}
