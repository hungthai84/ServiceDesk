# Environment Variables for Netlify and local development

# Google Gemini API Key for POW-AI assistant
GEMINI_API_KEY=

# Resend API Key for sending emails
RESEND_API_KEY=

# Cloud SQL Connection Variables (Provided at runtime)
SQL_HOST=
SQL_DB_NAME=
SQL_USER=
SQL_PASSWORD=
SQL_ADMIN_USER=
SQL_ADMIN_PASSWORD=
